DATABASE_URL=postgresql+asyncpg://basecamp:basecamp@postgres:5432/basecamp
JWT_SECRET=replace-with-a-long-random-secret
NEXTAUTH_SECRET=replace-with-a-long-random-nextauth-secret
ENVIRONMENT=local
# Comma-separated exact browser origins. Add the canonical Vercel production
# URL here in Render; preview deployments must be listed separately if used.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-basecamp.vercel.app
POSTGRES_DB=basecamp
POSTGRES_USER=basecamp
POSTGRES_PASSWORD=basecamp
POSTGRES_PORT=5432
